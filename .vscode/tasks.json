{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "git-add-changes",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"-A"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "git-commit-topup",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-m",
				"feat: rename balance button to 'Top Up' and add Top Up payment method"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "git-commit-topup-fix",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-m",
				"feat: rename balance button to Top Up and add Top Up payment method"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "git-push-topup",
			"type": "shell",
			"command": "git",
			"args": [
				"push",
				"origin",
				"main"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "local-rebuild-topup",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"up",
				"-d",
				"--build"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "check-containers",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"ps"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "check-logs-topup",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"logs",
				"--tail",
				"80",
				"odoo"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "wait-and-health",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Start-Sleep -Seconds 10; (Invoke-WebRequest -UseBasicParsing http://127.0.0.1:8069/health).StatusCode"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "final-logs-check",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"logs",
				"--tail",
				"40",
				"odoo"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "git-add-topup-fix",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"-A"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}