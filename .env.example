# Copy this file to .env and adjust values per team/environment.

# PostgreSQL
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

# RabbitMQ broker ports exposed on host
RABBIT_PORT=5672
RABBIT_MANAGEMENT_PORT=15672

# RabbitMQ application credentials (DO NOT use guest in production)
RABBIT_USER=team_kassa
RABBIT_PASSWORD=change_me_secure
RABBIT_VHOST=/

# Hostname used by app services inside Docker network
RABBIT_HOST=rabbitmq

# Odoo exposed port on host
ODOO_PORT=8069

# Heartbeat frequency in seconds
HEARTBEAT_INTERVAL_SECONDS=1
