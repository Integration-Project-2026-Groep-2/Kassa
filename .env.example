# Copy this file to .env and adjust values per environment.

# PostgreSQL
POSTGRES_DB=kassa_db
POSTGRES_USER=kassa
POSTGRES_PASSWORD=change_me_db_password
DB_HOST=db
DB_PORT=5432

# RabbitMQ
RABBIT_HOST=rabbitmq
RABBIT_PORT=5672
RABBIT_MANAGEMENT_PORT=15672
RABBIT_USER=team_kassa
RABBIT_PASSWORD=change_me_secure
RABBIT_VHOST=/

# Odoo
ODOO_PORT=8069
ODOO_DOMAIN=localhost:8069

# Service runtime
HEARTBEAT_INTERVAL_SECONDS=1
STATUS_CHECK_INTERVAL_SECONDS=30
SYSTEM_NAME=KASSA
LOG_LEVEL=info
SCHEMA_PATH=src/schema/kassa-schema-v1.xsd

# Heartbeat route
HEARTBEAT_EXCHANGE=heartbeat.direct
HEARTBEAT_ROUTING_KEY=routing.heartbeat
HEARTBEAT_QUEUE=heartbeat_queue

# User CRUD route
USER_EVENTS_EXCHANGE=user.direct
USER_EVENTS_EXCHANGE_TYPE=direct
USER_EVENTS_DLX_EXCHANGE=user.dlx
USER_EVENTS_RETRY_EXCHANGE=user.retry
USER_EVENTS_RETRY_TTL_MS=15000

# Optional receiver settings
POS_EXCHANGE=pos.events
POS_ROUTING_KEY=pos.#
POS_QUEUE=pos_messages
