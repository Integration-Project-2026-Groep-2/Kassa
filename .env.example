# .env.example - Environment Variables for Kassa Odoo Deployment
#
# IMPORTANT: Copy this file to .env and fill in actual values for your environment.
# NEVER commit the .env file with real passwords to version control!
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#   docker-compose up -d
#
# This configuration supports:
# - Team Kassa custom Odoo module
# - RabbitMQ message broker (AMQP + Management UI)
# - PostgreSQL database
# - POS Receiver and Heartbeat services
# - Nginx reverse proxy on Azure VM infrastructure

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# PostgreSQL credentials and connection details

# Database name (used by both PostgreSQL service and Odoo)
POSTGRES_DB=kassa_db

# PostgreSQL database user
POSTGRES_USER=kassa

# PostgreSQL database password
# SECURITY: Use strong password (min 20 characters, mixed alphanumeric + special chars)
POSTGRES_PASSWORD=<YOUR_SECURE_DB_PASSWORD_HERE>

# Database host
# LOCAL DEVELOPMENT: use 'db' (Docker Compose service name)
# AZURE DEPLOYMENT: use internal DNS name (e.g., 'postgres.integration-project-2026-groep-2.internal')
# EXTERNAL POSTGRES: use FQDN or IP address
DB_HOST=db

# Database port (standard PostgreSQL port)
DB_PORT=5432

# Optional: Directory to persist PostgreSQL data
# Uncomment and customize if needed
# POSTGRES_DATA_PATH=./data/postgres

# ============================================================
# RABBITMQ CONFIGURATION
# ============================================================
# RabbitMQ message broker credentials and connection details

# RabbitMQ hostname/FQDN
# LOCAL DEVELOPMENT: use 'rabbitmq' (Docker Compose service name)
# AZURE DEPLOYMENT: use internal DNS (e.g., 'rabbitmq.integration-project-2026-groep-2.internal')
# EXTERNAL RABBITMQ: use FQDN or IP address
RABBIT_HOST=rabbitmq

# RabbitMQ AMQP protocol port (message queue)
RABBIT_PORT=5672

# RabbitMQ management UI port (HTTPS - accessed via reverse proxy)
# Note: This is for reference only. Access via https://kassa.integration-project-2026-groep-2.my.be:15671
RABBIT_MANAGEMENT_PORT=15671

# RabbitMQ username
# Default: 'guest' (NOT recommended for production)
# Production: use service-specific user (e.g., 'kassa_user')
RABBIT_USER=kassa_user

# RabbitMQ password
# SECURITY: Use strong password (min 20 characters, mixed alphanumeric + special chars)
# IMPORTANT: Must match the database password's complexity requirements in your organization
RABBIT_PASSWORD=<YOUR_SECURE_RABBITMQ_PASSWORD_HERE>

# RabbitMQ virtual host (isolates message queues)
# Development: '/'
# Production: recommend isolated vhost (e.g., '/kassa')
RABBIT_VHOST=/kassa

# RabbitMQ Erlang Cookie (for clustering, if needed)
# Development: can use default
# Production: use strong random value (required for RabbitMQ clustering)
RABBIT_ERLANG_COOKIE=<RABBITMQ_ERLANG_COOKIE_HERE>

# Optional: Directory to persist RabbitMQ data
# Uncomment and customize if needed
# RABBITMQ_DATA_PATH=./data/rabbitmq

# ============================================================
# ODOO CONFIGURATION
# ============================================================
# Odoo web server and domain configuration

# Odoo internal HTTP port (inside container)
# Standard: 8069 (Odoo default)
# Do NOT change unless you have specific requirements
ODOO_PORT=8069

# Odoo public domain (via Nginx reverse proxy)
# This is the FQDN users will access in their browser
# Example: kassa.integration-project-2026-groep-2.my.be
ODOO_DOMAIN=kassa.integration-project-2026-groep-2.my.be

# Odoo log level
# Options: debug, info, warning, error, critical
LOG_LEVEL=info

# Optional: Directory to persist Odoo filestore and data
# Uncomment and customize if needed
# ODOO_DATA_PATH=./data/odoo

# ============================================================
# POS MESSAGE RECEIVER CONFIGURATION
# ============================================================
# Configuration for POS point-of-sale message consumer service

# RabbitMQ exchange name for POS events
POS_EXCHANGE=pos.events

# RabbitMQ routing key pattern for POS queue binding
POS_ROUTING_KEY=pos.#

# RabbitMQ queue name for POS messages
POS_QUEUE=pos_messages

# ============================================================
# HEARTBEAT SERVICE CONFIGURATION
# ============================================================
# Configuration for service health monitoring and heartbeat messages

# Interval between heartbeat messages (in seconds)
# Development: 1-5 seconds
# Production: 5-30 seconds (adjust based on load)
HEARTBEAT_INTERVAL_SECONDS=5

# RabbitMQ exchange name for heartbeat messages
HEARTBEAT_EXCHANGE=heartbeat.direct

# RabbitMQ routing key for heartbeat queue binding
HEARTBEAT_ROUTING_KEY=routing.heartbeat

# RabbitMQ queue name for heartbeat messages
HEARTBEAT_QUEUE=heartbeat_queue

# ============================================================
# AZURE INFRASTRUCTURE DETAILS (Reference)
# ============================================================
# 
# Infrastructure Components:
# 1. Azure Virtual Machine (Linux)
# 2. Docker Engine with Docker Compose
# 3. Nginx reverse proxy (external-facing)
# 4. PostgreSQL database (internal)
# 5. RabbitMQ message broker (internal)
# 6. Custom Odoo module (Kassa POS)
#
# Domain: integration-project-2026-groep-2.my.be
# - Odoo Application: kassa.integration-project-2026-groep-2.my.be (HTTPS)
# - RabbitMQ Management: kassa.integration-project-2026-groep-2.my.be:15671 (HTTPS)
#
# Network Architecture:
# 
#   Internet
#      ↓ (HTTPS)
#   Nginx Reverse Proxy (Port 443, 15671)
#      ↓ (HTTP, internal)
#   Docker Bridge Network (kassa-network)
#      ├── Odoo Container (internal port 8069)
#      ├── RabbitMQ Container (AMQP 5672, Management 15672)
#      ├── PostgreSQL Container (port 5432)
#      ├── POS Receiver Container
#      └── Heartbeat Container
#
# Database Connection: Internal only (no direct external access)
# RabbitMQ AMQP: Internal only (no direct external access)
# RabbitMQ Management: Via Nginx HTTPS proxy at port 15671

# ============================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================
#
# ✓ SECURITY:
#   [ ] Replace all <PASSWORD_HERE> placeholders with strong passwords
#   [ ] Password requirements:
#       - Minimum 20 characters
#       - Mix of uppercase, lowercase, numbers, special characters
#       - No dictionary words
#   [ ] Passwords should be different for each component (DB, RabbitMQ)
#   [ ] Passwords stored in Azure Key Vault (not in .env on disk)
#
# ✓ NETWORKING:
#   [ ] Nginx reverse proxy configured with SSL/TLS certificates
#   [ ] DNS subdomain points to Azure VM IP address
#   [ ] Azure Network Security Groups allow required ports
#   [ ] Firewall rules restrict direct access to containers
#
# ✓ CONFIGURATION:
#   [ ] RABBIT_HOST and DB_HOST set to internal Azure DNS names
#   [ ] ODOO_DOMAIN set to public subdomain
#   [ ] All service health checks enabled
#   [ ] Logging and monitoring configured
#
# ✓ BACKUP & RECOVERY:
#   [ ] PostgreSQL data persisted to Azure managed storage
#   [ ] RabbitMQ queues persisted
#   [ ] Odoo filestore backed up regularly
#   [ ] Recovery procedures documented
#
# ✓ MONITORING:
#   [ ] Application logs collected (Odoo + services)
#   [ ] RabbitMQ queue monitoring enabled
#   [ ] Database performance monitoring
#   [ ] Azure Monitor alerts configured

# ============================================================
# EXAMPLE CONFIGURATIONS FOR DIFFERENT ENVIRONMENTS
# ============================================================
#
# LOCAL DEVELOPMENT (localhost):
# POSTGRES_DB=kassa_dev
# POSTGRES_USER=kassa
# POSTGRES_PASSWORD=dev123
# DB_HOST=db
# RABBIT_HOST=rabbitmq
# RABBIT_USER=guest
# RABBIT_PASSWORD=guest
# RABBIT_VHOST=/
# ODOO_DOMAIN=localhost:8069
#
# STAGING ENVIRONMENT:
# POSTGRES_DB=kassa_staging
# POSTGRES_USER=kassa_staging_user
# POSTGRES_PASSWORD=<STRONG_PASSWORD>
# DB_HOST=postgres-staging.integration-project-2026-groep-2.internal
# RABBIT_HOST=rabbitmq-staging.integration-project-2026-groep-2.internal
# RABBIT_USER=kassa_staging_broker
# RABBIT_PASSWORD=<STRONG_PASSWORD>
# RABBIT_VHOST=/staging
# ODOO_DOMAIN=kassa-staging.integration-project-2026-groep-2.my.be
#
# PRODUCTION ENVIRONMENT:
# POSTGRES_DB=kassa_prod
# POSTGRES_USER=kassa_prod_user
# POSTGRES_PASSWORD=<STRONG_PASSWORD_FROM_AZURE_KEYVAULT>
# DB_HOST=postgres-prod.integration-project-2026-groep-2.internal
# RABBIT_HOST=rabbitmq-prod.integration-project-2026-groep-2.internal
# RABBIT_USER=kassa_prod_broker
# RABBIT_PASSWORD=<STRONG_PASSWORD_FROM_AZURE_KEYVAULT>
# RABBIT_VHOST=/kassa
# ODOO_DOMAIN=kassa.integration-project-2026-groep-2.my.be

# ============================================================
# RETRIEVING SECRETS FROM AZURE KEY VAULT (PRODUCTION)
# ============================================================
#
# Instead of committing passwords, retrieve from Azure Key Vault at startup:
#
# #!/bin/bash
# # get-secrets.sh
#
# VAULT_NAME="kassa-keyvault"
#
# # Retrieve each secret from Azure Key Vault
# export POSTGRES_PASSWORD=$(az keyvault secret show \
#   --vault-name "$VAULT_NAME" \
#   --name "postgres-password" \
#   --query value -o tsv)
#
# export RABBIT_PASSWORD=$(az keyvault secret show \
#   --vault-name "$VAULT_NAME" \
#   --name "rabbitmq-password" \
#   --query value -o tsv)
#
# # Start containers with secrets injected
# docker-compose up -d
#
# Make this script executable and run before docker-compose:
# chmod +x get-secrets.sh
# ./get-secrets.sh

# ============================================================
# NOTES FOR DEPLOYMENT ENGINEER
# ============================================================
#
# 1. This .env file controls all container configuration via variable substitution
#    in docker-compose.yml
#
# 2. Sensitive values (passwords) should NEVER be committed to Git
#    Use: git update-index --skip-worktree .env
#
# 3. For Azure deployments, integrate with Azure Key Vault or Azure Managed
#    Identities instead of storing passwords in .env
#
# 4. Each environment (dev, staging, prod) should have separate .env files:
#    - .env (local development)
#    - .env.staging (staging environment)
#    - Secrets retrieved at runtime from Azure Key Vault (production)
#
# 5. Test your configuration before production:
#    docker-compose config  # Validate and expand all variables
#    docker-compose up      # Test locally first
#    docker-compose logs    # Verify all services started correctly
