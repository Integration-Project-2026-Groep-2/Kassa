# Copy this file to .env and adjust values per environment.

# ============================================================
# DOCKER IMAGE - Single Consolidated Image
# ============================================================
# This single image contains:
# - Odoo 17 application
# - kassa_pos custom module (automatically installed)
# - src/ receiver services (Heartbeat, User registration, etc.)
ODOO_IMAGE=ghcr.io/integration-project-2026-groep-2/kassa:latest-dev

# PostgreSQL
POSTGRES_DB=kassa_db
POSTGRES_USER=kassa
POSTGRES_PASSWORD=change_me_db_password
DB_HOST=db
DB_PORT=5432

# RabbitMQ
RABBIT_HOST=rabbitmq
RABBIT_PORT=5672
RABBIT_MANAGEMENT_PORT=15672
RABBIT_USER=team_kassa
RABBIT_PASSWORD=change_me_secure
RABBIT_VHOST=/
RABBIT_ERLANG_COOKIE=secret_erlang_cookie_change_this

# Odoo
ODOO_URL=http://odoo:8069
ODOO_PORT=8069
ODOO_DOMAIN=localhost:8069
ODOO_DB=db
ODOO_USER=guest
ODOO_PASSWORD=guest
ODOO_SYNC_MODULES=
ODOO_SKIP_MODULE_SYNC=false

# Service runtime
HEARTBEAT_INTERVAL_SECONDS=1
STATUS_CHECK_INTERVAL_SECONDS=30
SYSTEM_NAME=KASSA
LOG_LEVEL=info
SCHEMA_PATH=src/schema/kassa-schema-v1.xsd

# Heartbeat route
HEARTBEAT_EXCHANGE=heartbeat.direct
HEARTBEAT_ROUTING_KEY=routing.heartbeat

# User CRUD route (Salesforce CRM integration)
USER_EVENTS_EXCHANGE=user.topic
USER_EVENTS_EXCHANGE_TYPE=topic

# Enable receivers inside Odoo container (both enabled by default)
ENABLE_HEARTBEAT_IN_ODOO_IMAGE=true
ENABLE_RECEIVER_IN_ODOO_IMAGE=true

# Optional receiver settings
POS_EXCHANGE=pos.events
POS_ROUTING_KEY=pos.#
POS_QUEUE=pos_messages
