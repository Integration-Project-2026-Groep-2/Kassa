<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action to trigger batch from backend - MUST BE DEFINED BEFORE VIEWS -->
    <record id="action_pos_order_batch_close_manual" model="ir.actions.server">
        <field name="name">Manual Batch Close</field>
        <field name="model_id" ref="model_pos_order"/>
        <field name="state">code</field>
        <field name="code">
session = env['pos.session'].browse(env.context.get('active_id'))
action = model.close_daily_batch(session=session)
        </field>
    </record>

    <!-- POS Session Form Extension -->
    <record id="view_pos_session_form_inherit_batch" model="ir.ui.view">
        <field name="name">pos.session.form.inherit.batch</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_pos_order_batch_close_manual)d" 
                        string="Batch Afsluiten (K-02)" 
                        type="action" 
                        class="oe_highlight"
                        invisible="state not in ['opened', 'closing_control', 'closed']"/>
            </xpath>
        </field>
    </record>

    <!-- POS Session Tree Extension -->
    <record id="view_pos_session_tree_inherit_batch" model="ir.ui.view">
        <field name="name">pos.session.tree.inherit.batch</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <button name="%(action_pos_order_batch_close_manual)d" 
                        string="Batch Afsluiten" 
                        type="action" 
                        icon="fa-save"
                        invisible="state not in ['opened', 'closing_control', 'closed']"/>
            </xpath>
        </field>
    </record>

    <!-- Batch Tree View -->
    <record id="view_pos_order_batch_tree" model="ir.ui.view">
        <field name="name">pos.order.batch.tree</field>
        <field name="model">pos.order.batch</field>
        <field name="arch" type="xml">
            <tree string="POS Batches" decoration-info="status == 'draft'" decoration-success="status in ['sent', 'confirmed']" decoration-danger="status == 'failed'">
                <field name="name"/>
                <field name="pos_session_id"/>
                <field name="created_date"/>
                <field name="total_orders"/>
                <field name="total_amount"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <!-- Batch Form View -->
    <record id="view_pos_order_batch_form" model="ir.ui.view">
        <field name="name">pos.order.batch.form</field>
        <field name="model">pos.order.batch</field>
        <field name="arch" type="xml">
            <form string="POS Batch">
                <header>
                    <button name="action_view_orders" string="View Orders" type="object" class="oe_highlight"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="batch_uuid"/>
                            <field name="pos_session_id"/>
                            <field name="created_date"/>
                        </group>
                        <group>
                            <field name="total_orders"/>
                            <field name="total_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="XML Payload">
                            <field name="xml_payload" widget="ace" options="{'mode': 'xml'}"/>
                        </page>
                        <page string="Error Log" invisible="not error_message">
                            <field name="error_message" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Batch Action -->
    <record id="action_pos_order_batch" model="ir.actions.act_window">
        <field name="name">POS Batches</field>
        <field name="res_model">pos.order.batch</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_pos_order_batch"
              name="Batches (Afsluitknop)"
              parent="point_of_sale.menu_point_rep"
              action="action_pos_order_batch"
              sequence="20"/>
</odoo>
