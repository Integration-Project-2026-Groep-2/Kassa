<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view: alle POS producten -->
    <record id="kassa_product_template_list_view" model="ir.ui.view">
        <field name="name">kassa.product.template.list</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="POS Producten">
                <field name="name"/>
                <field name="categ_id"/>
                <field name="list_price" string="Verkoopprijs"/>
                <field name="available_in_pos" string="Beschikbaar in POS"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form view: product aanmaken / bewerken -->
    <record id="kassa_product_template_form_view" model="ir.ui.view">
        <field name="name">kassa.product.template.form</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <form string="Product">
                <sheet>
                    <group>
                        <group string="Algemeen">
                            <field name="name" string="Naam"/>
                            <field name="categ_id" string="Categorie"/>
                            <field name="type" string="Type" required="1"/>
                        </group>
                        <group string="Prijs en POS">
                            <field name="list_price" string="Verkoopprijs"/>
                            <field name="available_in_pos" string="Beschikbaar in POS"/>
                            <field name="sale_ok" string="Verkoopbaar"/>
                            <field name="active" string="Actief"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Actie: open product lijst gefilterd op POS producten -->
    <record id="kassa_product_template_action" model="ir.actions.act_window">
        <field name="name">POS Producten</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('available_in_pos', '=', True)]</field>
        <field name="context">{'default_available_in_pos': True, 'default_type': 'consu', 'default_sale_ok': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('kassa_product_template_list_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('kassa_product_template_form_view')})]"/>
    </record>

    <!-- Menu onder Point of Sale > Producten beheren -->
    <menuitem
        id="kassa_menu_product_management"
        name="Producten beheren"
        parent="point_of_sale.menu_point_root"
        action="kassa_product_template_action"
        groups="point_of_sale.group_pos_manager"
        sequence="20"/>

</odoo>
