<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Product Categories -->
        <record id="product_category_drinks" model="product.category">
            <field name="name">Dranken</field>
        </record>

        <record id="product_category_food" model="product.category">
            <field name="name">Eten</field>
        </record>

        <!-- Dranken -->
        <record id="product_beer" model="product.product">
            <field name="name">Water</field>
            <field name="categ_id" ref="product_category_drinks"/>
            <field name="type">consu</field>
            <field name="list_price">1.50</field>
            <field name="available_in_pos">True</field>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
        </record>

        <record id="product_soda" model="product.product">
            <field name="name">Fanta</field>
            <field name="categ_id" ref="product_category_drinks"/>
            <field name="type">consu</field>
            <field name="list_price">2.25</field>
            <field name="available_in_pos">True</field>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
        </record>

        <record id="product_water" model="product.product">
            <field name="name">Cola</field>
            <field name="categ_id" ref="product_category_drinks"/>
            <field name="type">consu</field>
            <field name="list_price">2.25</field>
            <field name="available_in_pos">True</field>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
        </record>

        <!-- Eten -->
        <record id="product_coffee" model="product.product">
            <field name="name">Hamburger</field>
            <field name="categ_id" ref="product_category_food"/>
            <field name="type">consu</field>
            <field name="list_price">6.50</field>
            <field name="available_in_pos">True</field>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
        </record>

        <record id="product_fries" model="product.product">
            <field name="name">Frietjes</field>
            <field name="categ_id" ref="product_category_food"/>
            <field name="type">consu</field>
            <field name="list_price">3.50</field>
            <field name="available_in_pos">True</field>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
        </record>

    </data>
</odoo>
