<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Accounting Journals for Payment Methods -->
        <record id="account_journal_cash_kassa" model="account.journal" forcecreate="False">
            <field name="name">Kassa Cash</field>
            <field name="code">KCASH</field>
        </record>

        <record id="account_journal_bank_kassa" model="account.journal" forcecreate="False">
            <field name="name">Kassa Bank</field>
            <field name="code">KBANK</field>
        </record>

        <!-- Payment Methods -->
        <record id="payment_method_cash" model="pos.payment.method">
            <field name="name">Cash</field>
            <field name="journal_id" ref="account_journal_cash_kassa"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="payment_method_card" model="pos.payment.method">
            <field name="name">Bancontact</field>
            <field name="journal_id" ref="account_journal_bank_kassa"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="payment_method_invoice" model="pos.payment.method">
            <field name="name">Invoice</field>
            <field name="journal_id" ref="account_journal_bank_kassa"/>
            <field name="company_id" ref="base.main_company"/>
            <field name="split_transactions">True</field>
        </record>

        <!-- POS Configuration -->
        <record id="pos_config_kassa_main" model="pos.config">
            <field name="name">Kassa Main</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="payment_method_ids" eval="[(6, 0, [ref('payment_method_cash'), ref('payment_method_card'), ref('payment_method_invoice')])]"/>
            <field name="module_pos_restaurant">False</field>
            <field name="cash_control">True</field>
        </record>

    </data>
</odoo>
