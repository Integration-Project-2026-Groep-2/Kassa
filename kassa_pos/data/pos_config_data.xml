<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Pricelist in EUR -->
        <record id="pricelist_kassa_eur" model="product.pricelist">
            <field name="name">Kassa EUR</field>
            <field name="currency_id" ref="base.EUR"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!--
            NOTE: The 'Kassa Top Up' journal (account_journal_topup_kassa) is created
            by the pre_init_hook in __init__.py (code: KSALDO, type: bank).
            It is intentionally NOT declared here because Odoo forbids modifying
            the 'type' of a journal that already has an associated payment method,
            which causes a ParseError during fresh install on the VM.
        -->

        <!-- Top Up payment method — references the journal created by pre_init_hook -->
        <record id="pos_payment_method_topup" model="pos.payment.method">
            <field name="name">Top Up</field>
            <field name="journal_id" ref="account_journal_topup_kassa"/>
        </record>

    </data>
</odoo>
